{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "ECHO-CHAMBER": true
    }
  }
}
